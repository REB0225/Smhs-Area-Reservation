{
  "compilerOptions": {
    "module": "nodenext",
    "target": "esnext",
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "allowJs": true,
    "noImplicitAny": false
  },
  "include": ["backend/src/**/*", "api/**/*"],
  "exclude": ["node_modules", "frontend"]
}